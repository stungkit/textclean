meta <- packageDescription("textclean")

bibentry(
  bibtype = "Manual",
  title   = "textclean: Text Cleaning Tools",
  author  = person(meta$Author),
  year    = format(Sys.Date(), "%Y"),
  note    = paste("R package version", meta$Version),
  url     = meta$URL,
  textVersion = paste(
    meta$Author,
    sprintf("(%s).", format(Sys.Date(), "%Y")),
    "textclean: Text Cleaning Tools.",
    sprintf("R package version %s.", meta$Version),
    meta$URL
  )
)
